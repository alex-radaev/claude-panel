# install.tape -- Quick install demo
# Shows the one-liner to install claude-panel as a Claude Code plugin.
#
# Record: vhs demo/install.tape
# Output: demo/install.gif

Output demo/install.gif

# -- Window & font setup --------------------------------------------------
Set FontSize 18
Set Width 800
Set Height 400
Set Theme "Catppuccin Mocha"
Set TypingSpeed 80ms
Set Padding 20

# -- Install command -------------------------------------------------------
Type "claude plugin install claude-panel"
Enter
Sleep 4s
